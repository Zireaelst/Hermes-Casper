# ─────────────────────────────────────────────────────────────
# Hermes — environment template. Copy to `.env` and fill in.
# NEVER commit the real `.env`. Secrets stay local / in the vault.
# ─────────────────────────────────────────────────────────────

# ── MCP: GitHub (fine-grained PAT: repo, issues, pull_requests) ──
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── MCP: Supabase (Personal Access Token + project ref) ──
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# ── MCP: Context7 (optional API key for higher rate limits) ──
CONTEXT7_API_KEY=

# ── MCP: Casper (community casper-mcp — uses CSPR.cloud) ──
CSPR_CLOUD_API_KEY=
CASPER_MCP_NETWORK=testnet

# ── Casper network / x402 ──
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
X402_FACILITATOR_URL=http://localhost:4022
X402_PAYMENT_TOKEN_CONTRACT=   # HermesToken package hash from deploy_testnet

# ── Odra livenet deploy (Session J — see docs/setup/testnet-deploy.md) ──
# The secret key must be FUNDED (testnet faucet) and is NEVER committed.
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./casper-keys/secret_key.pem
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network/rpc
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.casper.network/events
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# ── Supabase app runtime (public + service) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI (Anthropic) ──
ANTHROPIC_API_KEY=
