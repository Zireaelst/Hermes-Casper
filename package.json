{
  "name": "hermes",
  "version": "0.0.0",
  "private": true,
  "description": "Hermes — the Commerce Layer for Autonomous AI Agents, built on Casper.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
