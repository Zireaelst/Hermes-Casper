# Hermes web app — environment configuration.
# Copy to .env.local and fill in. NEXT_PUBLIC_* are exposed to the browser;
# everything else is server-only (never shipped to the client).

# ── Data source (Supabase) ────────────────────────────────────────────────────
# When both are set (and HERMES_FORCE_DEMO != 1), the app reads/writes Supabase;
# otherwise it falls back to the in-memory demo store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Network / explorer ────────────────────────────────────────────────────────
# casper-test (default) or casper. Drives block-explorer links + CSPR.click.
NEXT_PUBLIC_CASPER_NETWORK=casper-test

# ── Wallet (CSPR.click) ───────────────────────────────────────────────────────
# `csprclick-template` is the public template app (works on testnet). Replace
# with the Hermes production appId from the CSPR.click dashboard when available.
NEXT_PUBLIC_CSPR_CLICK_APP_ID=csprclick-template

# ── Hero asset (optional) ─────────────────────────────────────────────────────
# Override the marketing hero background video with a Hermes-owned asset.
# NEXT_PUBLIC_HERO_VIDEO_URL=

# ── Demo switch ───────────────────────────────────────────────────────────────
# Set to 1 to force in-memory demo mode + simulated settlement (used by E2E).
# HERMES_FORCE_DEMO=1

# ── Agent API + autonomous agent (server-only) ────────────────────────────────
# Optional bearer token protecting /api/agent/* (and used by the MCP server).
# Leave unset to keep the agent API open (demo).
# HERMES_API_KEY=
#
# Autonomous /agents decision LLM. Any OpenAI-compatible provider works — set the
# key + base URL + model. Without a key it falls back to a deterministic policy
# agent. Examples:
#   OpenRouter (free tier):
#     HERMES_LLM_API_KEY=sk-or-...
#     HERMES_LLM_BASE_URL=https://openrouter.ai/api/v1
#     HERMES_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
#   NVIDIA NIM (free credits):
#     HERMES_LLM_API_KEY=nvapi-...
#     HERMES_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
#     HERMES_LLM_MODEL=meta/llama-3.1-70b-instruct
# HERMES_LLM_API_KEY=
# HERMES_LLM_BASE_URL=https://openrouter.ai/api/v1
# HERMES_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
#
# Anthropic native (alternative to the OpenAI-compatible path above):
# ANTHROPIC_API_KEY=
# HERMES_AGENT_MODEL=claude-sonnet-5

# ── On-chain settlement (server-only) ─────────────────────────────────────────
# All three must be set to enable real transfer_with_authorization settlement.
# X402_FACILITATOR_URL=http://localhost:4022
# X402_PAYMENT_TOKEN_CONTRACT=846fdfc631fe16515dddb4862ff81e43f5735b9b014a0b5d8352512ee712df2c
# HERMES_BUYER_KEY_PATH=./casper-keys/secret_key.pem
# HERMES_BUYER_KEY_ALGO=secp256k1
# CASPER_NETWORK_NAME=casper:casper-test
